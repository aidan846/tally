{
  "name": "tally",
  "version": "1.0.0",
  "description": "Simple, clean calculator app",
  "main": "src/index.js",
  "build": {
    "appId": "com.aidan.tally",
    "productName": "Tally",
    "directories": {
      "buildResources": "src/assets",
      "output": "build"
    },
    "afterAllArtifactBuild": "./scripts/organize-build.cjs",
    "mac": {
      "target": "dmg",
      "identity": null,
      "hardenedRuntime": false,
      "icon": "src/assets/icon.icns"
    },
    "win": {
      "target": "nsis",
      "icon": "src/assets/icon.png"
    },
    "linux": {
      "target": "AppImage"
    },
    "files": [
      "src/**/*",
      "package.json"
    ]
  },
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "build:mac": "electron-builder --mac --config.directories.output=build/mac && node scripts/organize-build.cjs build/mac",
    "build:win": "electron-builder --win --x64 --config.directories.output=build/win && node scripts/organize-build.cjs build/win",
    "build:both": "npm run build:mac && npm run build:win",
    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "lint": "echo \"No linting configured\"",
    "test": "node --experimental-default-type=module test/parser.test.mjs && node --experimental-default-type=module test/stocks.test.mjs"
  },
  "keywords": [],
  "author": {
    "name": "aidan846",
    "email": "lando.aidan@gmail.com"
  },
  "license": "GPL-3.0-only",
  "dependencies": {
    "electron-squirrel-startup": "^1.0.1",
    "mathjs": "^14.5.2"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.8.1",
    "@electron-forge/maker-deb": "^7.8.1",
    "@electron-forge/maker-rpm": "^7.8.1",
    "@electron-forge/maker-squirrel": "^7.8.1",
    "@electron-forge/maker-zip": "^7.8.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.8.1",
    "@electron-forge/plugin-fuses": "^7.8.1",
    "@electron/fuses": "^1.8.0",
    "electron": "37.1.0",
    "electron-builder": "^26.0.12"
  }
}
