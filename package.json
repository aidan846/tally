{
  "name": "tally",
  "version": "1.1.0",
  "description": "A simple calculator for your daily tasks.",
  "main": "src/index.js",
  "build": {
    "appId": "com.aidan.tally",
    "productName": "Tally",
    "directories": {
      "buildResources": "src/assets",
      "output": "build"
    },
    "afterAllArtifactBuild": "./scripts/organize-build.cjs",
    "mac": {
      "target": "dmg",
      "identity": null,
      "hardenedRuntime": false,
      "icon": "src/assets/icon.icns",
      "extendInfo": {
        "NSLocationWhenInUseUsageDescription": "Tally uses your location when you request local weather."
      }
    },
    "win": {
      "target": "nsis",
      "icon": "src/assets/icon.png",
      "signAndEditExecutable": false
    },
    "appx": {
      "applicationId": "Tally",
      "identityName": "aidan.TallySmartCalculator",
      "publisher": "CN=40932DBE-68FA-4D37-A0D1-3C0A3F21D656",
      "publisherDisplayName": "aidan846",
      "displayName": "Tally | Smart Calculator",
      "backgroundColor": "#111827",
      "showNameOnTiles": true
    },
    "linux": {
      "target": "AppImage"
    },
    "files": [
      "src/**/*",
      "package.json"
    ]
  },
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "build:mac": "electron-builder --mac --config.directories.output=build/mac && node scripts/organize-build.cjs build/mac",
    "build:win": "electron-builder --win --x64 --config.directories.output=build/win && node scripts/organize-build.cjs build/win",
    "build:win:x86": "electron-builder --win --ia32 --config.directories.output=build/win-x86 && node scripts/organize-build.cjs build/win-x86",
    "build:msix": "npm run build:msix:x64",
    "build:msix:x64": "set \"MSIX_ARCH=x64\" && electron-builder --win dir --x64 --config.directories.output=build/msix-unpacked-x64 --config.win.signAndEditExecutable=false && node scripts/package-msix.cjs",
    "build:msix:x86": "set \"MSIX_ARCH=x86\" && electron-builder --win dir --ia32 --config.directories.output=build/msix-unpacked-x86 --config.win.signAndEditExecutable=false && node scripts/package-msix.cjs",
    "build:linux": "electron-builder --linux --x64 --config.directories.output=build/linux && node scripts/organize-build.cjs build/linux",
    "build:win:all": "npm run build:win && npm run build:win:x86 && npm run build:msix:x64 && npm run build:msix:x86 && npm run build:pwa",
    "build:mac:all": "npm run build:mac && npm run build:win:all",
    "build:pwa": "node scripts/build-pwa.cjs",
    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "lint": "echo \"No linting configured\"",
    "test": "node test/parser.test.mjs && node test/stocks.test.mjs && node test/weather.test.mjs && node test/answer-format.test.mjs"
  },
  "keywords": [],
  "author": {
    "name": "aidan846",
    "email": "lando.aidan@gmail.com"
  },
  "license": "GPL-3.0-only",
  "dependencies": {
    "electron-squirrel-startup": "^1.0.1",
    "mathjs": "^14.5.2"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.8.1",
    "@electron-forge/maker-deb": "^7.8.1",
    "@electron-forge/maker-rpm": "^7.8.1",
    "@electron-forge/maker-squirrel": "^7.8.1",
    "@electron-forge/maker-zip": "^7.8.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.8.1",
    "@electron-forge/plugin-fuses": "^7.8.1",
    "@electron/fuses": "^1.8.0",
    "electron": "37.1.0",
    "electron-builder": "^26.0.12"
  },
  "allowScripts": {
    "electron@37.1.0": true
  }
}
